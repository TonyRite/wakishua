# Wakishua environment variables

# --- Production (Vercel serverless + Turso) ---
# Create a DB at https://turso.tech then: turso db show <name> --url
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# turso db tokens create <name>
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Local Express backend (server/) only ---
# JWT secret for the legacy auth flow (unused by the public posts UI).
JWT_SECRET=change-me-in-production
PORT=3001
